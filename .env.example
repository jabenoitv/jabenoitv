# ─────────────────────────────────────────────────────────────
# .env.example — copia este archivo a .env y rellena los valores.
# NUNCA subas el archivo .env real al repositorio (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# Puerto HTTP del servidor (opcional, default 3777)
PORT=3777

# Wallet del agente — REQUERIDO
# WALLET_PRIVATE_KEY es SECRETO. Nunca lo compartas ni lo subas a git.
WALLET_ADDRESS=0xTU_DIRECCION_DE_WALLET
WALLET_PRIVATE_KEY=0xTU_LLAVE_PRIVADA_SECRETA

# Anthropic / Claude — REQUERIDO y SECRETO
ANTHROPIC_API_KEY=sk-ant-REEMPLAZA_CON_TU_API_KEY

# ID del agente (opcional, default 51049)
AGENT_ID=51049

# Farcaster / Neynar
# NEYNAR_API_KEY: SECRETO, requerido para publicar en Farcaster
NEYNAR_API_KEY=REEMPLAZA_CON_TU_NEYNAR_API_KEY
# FARCASTER_SIGNER_UUID: SECRETO
FARCASTER_SIGNER_UUID=REEMPLAZA_CON_TU_SIGNER_UUID

# Secreto para proteger el dashboard — SECRETO, recomendado
DASHBOARD_SECRET=REEMPLAZA_CON_UN_SECRETO_FUERTE

# Modo de auto-publicación de bounties (opcional, default DRY-RUN)
# Valores típicos: DRY-RUN | LIVE
BOUNTY_AUTOPOST=DRY-RUN

# Flag de setup de gigs ya completado (opcional)
GIGS_SETUP_DONE=

# URL pública del servicio (opcional, p.ej. para callbacks/webhooks)
PUBLIC_URL=
